// What number to display
damage = 0; 

// Visuals
color = c_red;
alpha = 1.0;
scale = 0.5; // Starts small and pops up to full size!

// Movement
vsp = random_range(-1.5, -2.5); // Random upward speed
hsp = random_range(-0.5, 0.5);  // Slight random horizontal drift so numbers don't stack perfectly